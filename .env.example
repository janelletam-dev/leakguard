# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Bright Data
BRIGHTDATA_API_KEY=your-brightdata-api-key
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1
BRIGHTDATA_SERP_ZONE=serp_api1

# LangSmith (observability) — OFF by default. LangSmith stores the FULL prompt, which here
# includes raw paste content and any credentials in it. Enable ONLY for runs against the
# synthetic fixtures (e.g. the demo); never for real paste data.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=ls-your-key-here
LANGSMITH_PROJECT=leakguard

# Slack alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
